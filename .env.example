# Shared keys for the Claude-Cloud sandbox.
#
# Copy to `.env` at the repo root and fill in real values for LOCAL runs:
#   cp .env.example .env
# `.env` is git-ignored. In CI these come from GitHub Actions repository secrets,
# not this file. `sandbox.env.load_env()` reads the repo-root `.env`.
#
# Keys are defined once here for the whole sandbox; individual projects use only
# the ones they need.

# Notion integration token (used by notion-emoji-tagger). Starts with `ntn_`.
NOTION_TOKEN=

# Anthropic API key. Starts with `sk-ant-`.
ANTHROPIC_API_KEY=
